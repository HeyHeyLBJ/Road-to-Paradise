    var colorHex = {
        "Democrat": "#4C72B0",
        "Republican": "#C44E52",
        "Independent": "#8C8C8C"
    };

    var width = 640, height = 720;
    var svgEl = document.getElementById("ca-district-svg");
    var contentWidth = document.getElementById("content").offsetWidth;
    if (contentWidth < width) {
        width = contentWidth;
        height = width * (720 / 640);
        svgEl.style.height = height + "px";
    }

    var projection = d3.geoAlbers().fitSize([width, height], geojson);
    var path = d3.geoPath(projection);

    d3.select("#ca-district-svg")
        .selectAll("path")
        .data(geojson.features)
        .join("path")
            .attr("d", path)
            .attr("fill", function(d) { return colorHex[d.properties.PARTY] || "#8C8C8C"; })
            .attr("stroke", "#0f1115")
            .attr("stroke-width", 0.6)
            .style("cursor", "pointer")
            .on("mouseover", function() { d3.select(this).style("opacity", 0.85); })
            .on("mouseout", function() { d3.select(this).style("opacity", 1); })
            .on("click", function(event, d) {
                Q['selected_district'] = d.properties.DISTRICT;
            })
        .append("title")
            .text(function(d) { return "District " + d.properties.DISTRICT + " — " + d.properties.PARTY; });
!}

The state's districts, colored by the party currently holding each seat.

{!<svg id="ca-district-svg" style="width: 100%; max-width: 640px; height: 720px; display: block;"></svg>!}
